# used by intellij
# ignore these types of java files
*.class
*.jar
*.war
*.rar
*.gar

# ignore these IntelliJ files
.idea
*.iml
*.ipr
*.iws

# ignore these hidden and build specific files
.*
~*

# ignore these folders
target
dist
_package
store-bdb-active
store-bdb-trash

#ignore these specific files
dependency-reduced-pom.xml

# however allow these files
!.ignore
!.github
!.gitignore
!.mvn
# Track the golangci-lint v2 configuration so CI uses the same correctness-focused checks as local runs.
# Expected behavior: the ignored hidden-file rule still applies broadly, while the linter config is versioned.
!.golangci.yml

# Go

bin/
build/
shared/
certs/
release/
etc/
coherence/coherence.test
runner
